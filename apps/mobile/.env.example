# Copy to `.env` and adjust. Never commit real `.env`.

# Dev only: enable release-style diagnostics + Settings → Version (5 taps) log viewer.
# EXPO_PUBLIC_DIAGNOSTICS=true

# Expo dev: LAN IP is fine. Release APK must use HTTPS (e.g. Render) unless usesCleartextTraffic is enabled.
# EAS preview/production sets EXPO_PUBLIC_API_URL in eas.json — Gradle-only builds must match here before assembleRelease.
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# OAuth / Google — use values from your Firebase / Google Cloud console
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Supabase — must match production (snewjtukygzebeeyjpwq) and backend SUPABASE_URL on Render
EXPO_PUBLIC_SUPABASE_URL=https://snewjtukygzebeeyjpwq.supabase.co
# Supabase Dashboard → Project Settings → API → anon public key (required for Google / Apple login)
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNuZXdqdHVreWd6ZWJlZXlqcHdxIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODAzOTU4MjAsImV4cCI6MjA5NTk3MTgyMH0.DRDV5PWS_C5KpZsE-EoRsgQl3OKdWE7n0naS183-ysw

# Phone OTP is now WhatsApp-only via our own backend (Meta WhatsApp Cloud API) — no Supabase /
# Twilio involvement on the phone path. The app just calls /auth/whatsapp/{send,verify,bind};
# all WhatsApp credentials live on the backend (see apps/backend/.env.example).

# EAS cloud builds: eas env:create EXPO_PUBLIC_SUPABASE_ANON_KEY --value "<anon-key>" --environment preview --environment production --environment development

# Sign in with Apple (iOS only) — one-time dashboard setup (no extra env vars in the app):
# 1. Apple Developer → App ID com.hakalive.app → enable Sign In with Apple; create a .p8 key (Team ID + Key ID).
# 2. Supabase → Authentication → Providers → Apple → Client ID = com.hakalive.app, Secret = JWT from .p8 key.
# 3. Rebuild iOS dev client: eas build --platform ios --profile development

# Internal QA only: skip Supabase phone OTP on Become Agent (Expo Go skips automatically).
# Do not enable for store production builds.
# EXPO_PUBLIC_SKIP_AGENT_OTP=true

# Internal QA only: Haka ID login uses /auth/dev-login-haka (shared dev password fallback).
# Release APK uses /auth/login (user must have a bcrypt password set). Do not enable for store builds.
# EXPO_PUBLIC_ENABLE_DEV_LOGIN=true
