{
  "name": "haka-live",
  "version": "1.0.0",
  "main": "./App",
  "scripts": {
    "start": "expo start",
    "android": "bash scripts/with-jdk17.sh expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "postinstall": "patch-package && node scripts/postinstall-fixes.mjs",
    "eas-build-pre-install": "bash ../../scripts/check-asset-size.sh scan ./assets && bash ../../scripts/check-asset-size.sh scan ./src/assets",
    "eas-build-post-install": "patch-package && node scripts/postinstall-fixes.mjs"
  },
  "dependencies": {
    "@jayming/svga-player-rn": "^0.4.0",
    "@notifee/react-native": "^9.1.8",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@reduxjs/toolkit": "^2.2.7",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "expo": "~54.0.0",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-localization": "~17.0.9",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-print": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "i18next": "^26.3.1",
    "react": "19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-agora": "^4.6.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-nitro-image": "^0.15.0",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-razorpay": "^3.0.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-vision-camera": "^5.0.11",
    "react-native-vision-camera-face-detector": "^2.0.1",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.3",
    "react-redux": "^9.1.2",
    "rn-emoji-keyboard": "^1.7.0",
    "socket.io-client": "^4.8.3"
  },
  "expo": {
    "install": {
      "exclude": []
    },
    "autolinking": {
      "buildFromSource": [
        "expo-video",
        "expo-audio"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-razorpay",
          "@jayming/svga-player-rn",
          "react-native-vision-camera-face-detector"
        ],
        "listUnknownPackages": false
      },
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "patch-package": "^8.0.1",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "~5.9.2"
  },
  "private": true
}
