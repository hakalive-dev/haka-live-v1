{
  "name": "@haka-live/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node --watch -r ts-node/register src/server.ts",
    "dev:worker": "ts-node src/worker.ts",
    "worker": "node dist/worker.js",
    "build": "tsc && if [ -d ../admin ]; then cd ../admin && npm install && npm run build && cp -r dist ../backend/admin-dist; fi",
    "start": "node dist/server.js",
    "loadtest:ws": "ts-node scripts/ws-ccu-smoke.ts",
    "otp:smoke": "ts-node scripts/email-otp-smoke.ts",
    "test": "jest --runInBand --forceExit --detectOpenHandles",
    "test:db:reset": "bash scripts/test-db-reset.sh",
    "backup:db": "bash scripts/backup-db.sh",
    "prisma:resolve:add_room_members": "npx prisma migrate resolve --schema prisma/schema.prisma --applied 20260508185200_add_room_members",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "seed": "ts-node prisma/seed.ts",
    "seed:demo": "ts-node prisma/seed-demo.ts",
    "seed:activity": "ts-node prisma/seed-activity.ts",
    "seed:room-seats": "ts-node prisma/seed-room-seats.ts",
    "seed:withdrawal-message": "ts-node scripts/seed-withdrawal-message-sample.ts",
    "seed:admin": "ts-node prisma/seed-admin.ts",
    "seed:female-host": "ts-node prisma/seed-female-host.ts",
    "seed:testuser": "ts-node prisma/seed-testuser.ts",
    "backfill:haka-ids": "ts-node prisma/backfill-haka-ids.ts",
    "backfill:gift-commission": "ts-node prisma/backfill-gift-commission.ts",
    "backfill:charm-xp": "ts-node prisma/backfill-charm-xp.ts",
    "backfill:last-live": "ts-node prisma/backfill-last-live.ts",
    "backfill:welcome-dm": "ts-node src/scripts/backfill-welcome-dm.ts",
    "backfill:image-ceiling": "ts-node scripts/backfill-image-ceiling.ts",
    "rekognition:setup": "ts-node scripts/setup-rekognition.ts",
    "rekognition:check": "ts-node scripts/setup-rekognition.ts --check"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.1048.0",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.45.0",
    "@types/node-cron": "^3.0.11",
    "adm-zip": "^0.5.16",
    "agora-access-token": "^2.0.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.8",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "firebase-admin": "^12.7.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "razorpay": "^2.9.6",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "stripe": "^22.0.1",
    "uuid": "^10.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "ioredis-mock": "^8.13.1",
    "jest": "^29.7.0",
    "pg": "^8.20.0",
    "prisma": "^5.22.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts",
    "seed:admin": "ts-node prisma/seed-admin.ts"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/prisma/migrations"
    ],
    "setupFiles": [
      "./src/tests/setup.ts"
    ],
    "globalSetup": "./src/tests/jest.global-setup.ts",
    "globalTeardown": "./src/tests/jest.global-teardown.ts",
    "clearMocks": true,
    "testTimeout": 30000
  }
}
