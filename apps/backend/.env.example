# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (PostgreSQL via Prisma) ──────────────────────────
DATABASE_URL=postgresql://hakalive:hakalive@db:5432/hakalive_dev
# For Supabase: DIRECT_URL is the direct (non-pooled) connection for migrations
# DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# TEST_DATABASE_URL — used by `npm test` and `npm run test:db:reset`. MUST be a
# LOCAL Postgres. `test:db:reset` runs `prisma migrate reset` (destructive) and
# refuses to run unless this host is localhost/127.0.0.1/::1/db/postgres, so it
# can never wipe a remote/live database.
TEST_DATABASE_URL=postgresql://hakalive:hakalive@localhost:5433/hakalive_test

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# Set to `false` on horizontally scaled API nodes when a dedicated `npm run worker` process runs schedulers + BullMQ (see src/worker.ts).
ENABLE_SCHEDULER=true

# ── JWT ───────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-this-to-a-long-random-hex-string
JWT_REFRESH_SECRET=change-this-to-another-long-random-hex-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Firebase Admin SDK ────────────────────────────────────────
# From Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key exactly as-is (including \n characters)
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----\n"

# ── Supabase ──────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API
# Used for Google / Apple / Phone OTP session verification (auth.getUser)
SUPABASE_URL=https://snewjtukygzebeeyjpwq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
# Phone OTP: Supabase Dashboard → Authentication → Providers → Phone → Twilio Verify.
#
# Storage buckets (Dashboard → Storage). Public buckets required for chat photos:
#   dm-chat-images, room-chat-images, admin-uploads
# See docs/deploy/supabase-storage-buckets.md

# ── AWS (S3 optional; Rekognition required for face verification) ─
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=eu-west-1

# Face verification — Rekognition collection (create with: npm run rekognition:setup)
REKOGNITION_FACE_COLLECTION_ID=haka-live-faces
REKOGNITION_REGION=eu-west-1

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# ── Payment method encryption (withdrawal payout bind) ─────────
# Required in production. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_ENCRYPTION_KEY=

# ── WhatsApp OTP (Meta WhatsApp Cloud API) ────────────────────
# Self-owned phone-login OTP. Get PHONE_NUMBER_ID from Meta > WhatsApp > API Setup.
# ACCESS_TOKEN must be a PERMANENT System User token (not the 24h dashboard token).
# Leave blank until Meta-side setup (verified WABA + approved `haka_otp` template) is done.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=haka_otp
WHATSAPP_TEMPLATE_LANG=en_US
WHATSAPP_API_VERSION=v21.0

# ── Agora (used from Feature 4 onwards) ───────────────────────
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000


# ── Admin panel ───────────────────────────────────────────────
# REQUIRED — server will not start without these set.
# ADMIN_INITIAL_EMAIL and ADMIN_INITIAL_PASSWORD are used only on first
# deploy to seed the super-admin account (skipped if an admin already exists).
ADMIN_JWT_SECRET=change-me-min-32-chars-random-string
ADMIN_INITIAL_EMAIL=admin@yourdomain.com
ADMIN_INITIAL_PASSWORD=change-me-min-12-chars
